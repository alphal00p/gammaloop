{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuntimeSettings",
  "type": "object",
  "properties": {
    "General": {
      "$ref": "#/$defs/GeneralSettings"
    },
    "Integrand": {
      "anyOf": [
        {
          "$ref": "#/$defs/IntegrandSettings"
        },
        {
          "type": "null"
        }
      ]
    },
    "Integrator": {
      "$ref": "#/$defs/IntegratorSettings"
    },
    "Kinematics": {
      "$ref": "#/$defs/KinematicsSettings"
    },
    "Observables": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ObservableSettings"
      }
    },
    "Selectors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/PhaseSpaceSelectorSettings"
      }
    },
    "stability": {
      "$ref": "#/$defs/stabilitySettings"
    },
    "sampling": {
      "$ref": "#/$defs/SamplingSettings"
    },
    "subtraction": {
      "$ref": "#/$defs/SubtractionSettings"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "AFBSettings": {
      "type": "object",
      "properties": {
        "filename": {
          "type": "string"
        },
        "n_bins": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "write_to_file": {
          "type": "boolean"
        },
        "x_max": {
          "type": "number",
          "format": "double"
        },
        "x_min": {
          "type": "number",
          "format": "double"
        }
      },
      "required": ["x_min", "x_max", "n_bins", "write_to_file", "filename"]
    },
    "Dep": {
      "type": "string",
      "enum": ["dependent"]
    },
    "DiscreteGraphSamplingType": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "b": {
              "type": "number",
              "format": "double"
            },
            "input_rescaling": {
              "description": "todo make proper type for this object",
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "array",
                  "maxItems": 2,
                  "minItems": 2,
                  "prefixItems": [
                    {
                      "type": "number",
                      "format": "double"
                    },
                    {
                      "type": "number",
                      "format": "double"
                    }
                  ]
                }
              }
            },
            "mapping": {
              "$ref": "#/$defs/ParameterizationMapping"
            },
            "mode": {
              "$ref": "#/$defs/ParameterizationMode"
            },
            "shifts": {
              "description": "todo make proper type for this object",
              "type": "array",
              "items": {
                "type": "array",
                "maxItems": 4,
                "minItems": 4,
                "prefixItems": [
                  {
                    "type": "number",
                    "format": "double"
                  },
                  {
                    "type": "number",
                    "format": "double"
                  },
                  {
                    "type": "number",
                    "format": "double"
                  },
                  {
                    "type": "number",
                    "format": "double"
                  }
                ]
              }
            },
            "subtype": {
              "type": "string",
              "const": "default"
            }
          },
          "additionalProperties": false,
          "required": ["subtype"]
        },
        {
          "type": "object",
          "properties": {
            "alpha": {
              "type": "number",
              "format": "double"
            },
            "parameterization_settings": {
              "$ref": "#/$defs/ParameterizationSettings"
            },
            "subtype": {
              "type": "string",
              "const": "multi_channeling"
            }
          },
          "additionalProperties": false,
          "required": ["subtype"]
        },
        {
          "type": "object",
          "properties": {
            "alpha": {
              "type": "number",
              "format": "double"
            },
            "parameterization_settings": {
              "$ref": "#/$defs/ParameterizationSettings"
            },
            "subtype": {
              "type": "string",
              "const": "discrete_multi_channeling"
            }
          },
          "additionalProperties": false,
          "required": ["subtype"]
        },
        {
          "type": "object",
          "properties": {
            "matrix_stability_test": {
              "type": ["number", "null"],
              "format": "double"
            },
            "subtype": {
              "type": "string",
              "const": "tropical"
            },
            "upcast_on_failure": {
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "required": ["subtype"]
        }
      ]
    },
    "ExternalMomenta": {
      "anyOf": [
        {
          "$ref": "#/$defs/Dep"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/F"
          },
          "maxItems": 4,
          "minItems": 4
        }
      ]
    },
    "Externals": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "helicities": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/SignOrZero"
                  }
                },
                "momenta": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/ExternalMomenta"
                  }
                }
              },
              "additionalProperties": false,
              "required": ["momenta", "helicities"]
            },
            "type": {
              "type": "string",
              "const": "constant"
            }
          },
          "additionalProperties": false,
          "required": ["type", "data"]
        }
      ]
    },
    "F": {
      "type": "number",
      "format": "double"
    },
    "FilterQuantity": {
      "type": "string",
      "enum": ["E", "CosTheta", "PT"]
    },
    "GeneralSettings": {
      "type": "object",
      "properties": {
        "enable_cache": {
          "type": "boolean"
        },
        "load_compiled_cff": {
          "type": "boolean"
        },
        "m_uv": {
          "type": "number",
          "format": "double"
        },
        "mu_r_sq": {
          "type": "number",
          "format": "double"
        },
        "orientation_pat": {
          "$ref": "#/$defs/OrientationPattern"
        },
        "use_ltd": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "HFunction": {
      "type": "string",
      "enum": [
        "poly_exponential",
        "exponential",
        "poly_left_right_exponential",
        "exponential_ct"
      ]
    },
    "HFunctionSettings": {
      "type": "object",
      "properties": {
        "enabled_dampening": {
          "type": "boolean"
        },
        "function": {
          "$ref": "#/$defs/HFunction"
        },
        "power": {
          "type": ["integer", "null"],
          "format": "uint",
          "minimum": 0
        },
        "sigma": {
          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": false
    },
    "HFunctionTestSettings": {
      "type": "object",
      "properties": {
        "h_function": {
          "$ref": "#/$defs/HFunctionSettings"
        }
      },
      "required": ["h_function"]
    },
    "IntegrandSettings": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "unit_surface"
            }
          },
          "$ref": "#/$defs/UnitSurfaceSettings",
          "required": ["type"]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "unit_volume"
            }
          },
          "$ref": "#/$defs/UnitVolumeSettings",
          "required": ["type"]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "h_function_test"
            }
          },
          "$ref": "#/$defs/HFunctionTestSettings",
          "required": ["type"]
        }
      ]
    },
    "IntegratedCounterTermRange": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "h_function_settings": {
              "$ref": "#/$defs/HFunctionSettings"
            },
            "type": {
              "type": "string",
              "const": "infinite"
            }
          },
          "additionalProperties": false,
          "required": ["type", "h_function_settings"]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "compact"
            }
          },
          "additionalProperties": false,
          "required": ["type"]
        }
      ]
    },
    "IntegratedCounterTermSettings": {
      "type": "object",
      "properties": {
        "range": {
          "$ref": "#/$defs/IntegratedCounterTermRange"
        }
      },
      "additionalProperties": false
    },
    "IntegratedPhase": {
      "type": "string",
      "enum": ["real", "imag", "both"]
    },
    "IntegratorSettings": {
      "type": "object",
      "properties": {
        "bin_number_evolution": {
          "type": ["array", "null"],
          "items": {
            "type": "integer",
            "format": "uint",
            "minimum": 0
          }
        },
        "continuous_dim_learning_rate": {
          "type": "number",
          "format": "double"
        },
        "discrete_dim_learning_rate": {
          "type": "number",
          "format": "double"
        },
        "integrated_phase": {
          "$ref": "#/$defs/IntegratedPhase"
        },
        "max_prob_ratio": {
          "type": "number",
          "format": "double"
        },
        "min_samples_for_update": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "n_bins": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "n_increase": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "n_max": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "n_start": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "seed": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "show_max_wgt_info": {
          "type": "boolean"
        },
        "train_on_avg": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "Jet1PTSettings": {
      "type": "object",
      "properties": {
        "dR": {
          "type": "number",
          "format": "double"
        },
        "filename": {
          "type": "string"
        },
        "min_jpt": {
          "type": "number",
          "format": "double"
        },
        "n_bins": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "use_fastjet": {
          "type": "boolean"
        },
        "write_to_file": {
          "type": "boolean"
        },
        "x_max": {
          "type": "number",
          "format": "double"
        },
        "x_min": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "x_min",
        "x_max",
        "dR",
        "min_jpt",
        "n_bins",
        "write_to_file",
        "filename",
        "use_fastjet"
      ]
    },
    "JetSliceSettings": {
      "type": "object",
      "properties": {
        "dR": {
          "type": "number",
          "format": "double"
        },
        "max_j1pt": {
          "type": "number",
          "format": "double"
        },
        "max_jets": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "min_j1pt": {
          "type": "number",
          "format": "double"
        },
        "min_jets": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "min_jpt": {
          "type": "number",
          "format": "double"
        },
        "use_fastjet": {
          "type": "boolean"
        }
      },
      "required": [
        "min_jets",
        "max_jets",
        "min_j1pt",
        "max_j1pt",
        "dR",
        "min_jpt",
        "use_fastjet"
      ]
    },
    "KinematicsSettings": {
      "type": "object",
      "properties": {
        "e_cm": {
          "type": "number",
          "format": "double"
        },
        "externals": {
          "$ref": "#/$defs/Externals"
        }
      },
      "additionalProperties": false
    },
    "LocalCounterTermSettings": {
      "type": "object",
      "properties": {
        "uv_localisation": {
          "$ref": "#/$defs/UVLocalisationSettings"
        }
      },
      "additionalProperties": false
    },
    "ObservableSettings": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "jet1pt"
            }
          },
          "$ref": "#/$defs/Jet1PTSettings",
          "required": ["type"]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "one_particle_obs"
            }
          },
          "$ref": "#/$defs/SingleParticleObservableSettings",
          "required": ["type"]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "AFB"
            }
          },
          "$ref": "#/$defs/AFBSettings",
          "required": ["type"]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "cross_section"
            }
          },
          "required": ["type"]
        }
      ]
    },
    "OrientationPattern": {
      "type": "object",
      "properties": {
        "pat": {
          "anyOf": [
            {
              "$ref": "#/$defs/ParseableAtom"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "OverlapSettings": {
      "type": "object",
      "properties": {
        "check_global_center": {
          "type": "boolean"
        },
        "force_global_center": {
          "type": ["array", "null"],
          "items": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "double"
            },
            "maxItems": 3,
            "minItems": 3
          }
        },
        "try_origin": {
          "type": "boolean"
        },
        "try_origin_all_lmbs": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "ParameterizationMapping": {
      "type": "string",
      "enum": ["log", "linear"]
    },
    "ParameterizationMode": {
      "type": "string",
      "enum": [
        "cartesian",
        "spherical",
        "hyperspherical",
        "hyperspherical_flat"
      ]
    },
    "ParameterizationSettings": {
      "type": "object",
      "properties": {
        "b": {
          "type": "number",
          "format": "double"
        },
        "input_rescaling": {
          "description": "todo make proper type for this object",
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "array",
              "maxItems": 2,
              "minItems": 2,
              "prefixItems": [
                {
                  "type": "number",
                  "format": "double"
                },
                {
                  "type": "number",
                  "format": "double"
                }
              ]
            }
          }
        },
        "mapping": {
          "$ref": "#/$defs/ParameterizationMapping"
        },
        "mode": {
          "$ref": "#/$defs/ParameterizationMode"
        },
        "shifts": {
          "description": "todo make proper type for this object",
          "type": "array",
          "items": {
            "type": "array",
            "maxItems": 4,
            "minItems": 4,
            "prefixItems": [
              {
                "type": "number",
                "format": "double"
              },
              {
                "type": "number",
                "format": "double"
              },
              {
                "type": "number",
                "format": "double"
              },
              {
                "type": "number",
                "format": "double"
              }
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "ParseableAtom": {
      "description": "An atom that is serialized as a string. Do not make any assumptions about the state",
      "type": ["string"]
    },
    "PhaseSpaceSelectorSettings": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "jet"
            }
          },
          "$ref": "#/$defs/JetSliceSettings",
          "required": ["type"]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "ranged"
            }
          },
          "$ref": "#/$defs/RangeFilterSettings",
          "required": ["type"]
        }
      ]
    },
    "Precision": {
      "type": "string",
      "enum": ["Double", "Quad", "Arb"]
    },
    "RangeFilterSettings": {
      "type": "object",
      "properties": {
        "filter": {
          "$ref": "#/$defs/FilterQuantity"
        },
        "max_value": {
          "type": "number",
          "format": "double"
        },
        "min_value": {
          "type": "number",
          "format": "double"
        },
        "pdgs": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "int"
          }
        }
      },
      "required": ["pdgs", "filter", "min_value", "max_value"]
    },
    "RotationSetting": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "x"
            }
          },
          "additionalProperties": false,
          "required": ["type"]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "y"
            }
          },
          "additionalProperties": false,
          "required": ["type"]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "z"
            }
          },
          "additionalProperties": false,
          "required": ["type"]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "none"
            }
          },
          "additionalProperties": false,
          "required": ["type"]
        },
        {
          "type": "object",
          "properties": {
            "alpha": {
              "type": "number",
              "format": "double"
            },
            "beta": {
              "type": "number",
              "format": "double"
            },
            "gamma": {
              "type": "number",
              "format": "double"
            },
            "type": {
              "type": "string",
              "const": "euler_angles"
            }
          },
          "additionalProperties": false,
          "required": ["type", "alpha", "beta", "gamma"]
        }
      ]
    },
    "SamplingSettings": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "b": {
              "type": "number",
              "format": "double"
            },
            "input_rescaling": {
              "description": "todo make proper type for this object",
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "array",
                  "maxItems": 2,
                  "minItems": 2,
                  "prefixItems": [
                    {
                      "type": "number",
                      "format": "double"
                    },
                    {
                      "type": "number",
                      "format": "double"
                    }
                  ]
                }
              }
            },
            "mapping": {
              "$ref": "#/$defs/ParameterizationMapping"
            },
            "mode": {
              "$ref": "#/$defs/ParameterizationMode"
            },
            "shifts": {
              "description": "todo make proper type for this object",
              "type": "array",
              "items": {
                "type": "array",
                "maxItems": 4,
                "minItems": 4,
                "prefixItems": [
                  {
                    "type": "number",
                    "format": "double"
                  },
                  {
                    "type": "number",
                    "format": "double"
                  },
                  {
                    "type": "number",
                    "format": "double"
                  },
                  {
                    "type": "number",
                    "format": "double"
                  }
                ]
              }
            },
            "type": {
              "type": "string",
              "const": "default"
            }
          },
          "additionalProperties": false,
          "required": ["type"]
        },
        {
          "type": "object",
          "properties": {
            "alpha": {
              "type": "number",
              "format": "double"
            },
            "parameterization_settings": {
              "$ref": "#/$defs/ParameterizationSettings"
            },
            "type": {
              "type": "string",
              "const": "multi_channeling"
            }
          },
          "additionalProperties": false,
          "required": ["type"]
        },
        {
          "type": "object",
          "properties": {
            "sample_orientations": {
              "type": "boolean"
            },
            "sampling_type": {
              "$ref": "#/$defs/DiscreteGraphSamplingType"
            },
            "type": {
              "type": "string",
              "const": "discrete_graph_sampling"
            }
          },
          "additionalProperties": false,
          "required": ["type"]
        }
      ]
    },
    "SignOrZero": {
      "type": "string",
      "enum": ["Zero", "Plus", "Minus"]
    },
    "SingleParticleObservableSettings": {
      "type": "object",
      "properties": {
        "filename": {
          "type": "string"
        },
        "log_obs": {
          "type": "boolean",
          "default": false
        },
        "log_x_axis": {
          "type": "boolean",
          "default": false
        },
        "log_y_axis": {
          "type": "boolean",
          "default": true
        },
        "n_bins": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "pdgs": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "int"
          }
        },
        "quantity": {
          "$ref": "#/$defs/FilterQuantity"
        },
        "write_to_file": {
          "type": "boolean",
          "default": true
        },
        "x_max": {
          "type": "number",
          "format": "double"
        },
        "x_min": {
          "type": "number",
          "format": "double"
        }
      },
      "required": ["x_min", "x_max", "n_bins", "filename", "pdgs", "quantity"]
    },
    "StabilityLevelSetting": {
      "type": "object",
      "properties": {
        "escalate_for_large_weight_threshold": {
          "type": "number",
          "format": "double"
        },
        "precision": {
          "$ref": "#/$defs/Precision"
        },
        "required_precision_for_im": {
          "type": "number",
          "format": "double"
        },
        "required_precision_for_re": {
          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": false,
      "required": [
        "precision",
        "required_precision_for_re",
        "required_precision_for_im",
        "escalate_for_large_weight_threshold"
      ]
    },
    "StabilityRecordingSettings": {
