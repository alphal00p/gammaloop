{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuntimeSettings",
  "type": "object",
  "properties": {
    "general": {
      "$ref": "#/$defs/GeneralSettings"
    },
    "h_function": {
      "$ref": "#/$defs/HFunctionSettings"
    },
    "integrand": {
      "anyOf": [
        {
          "$ref": "#/$defs/IntegrandSettings"
        },
        {
          "type": "null"
        }
      ]
    },
    "integrator": {
      "$ref": "#/$defs/IntegratorSettings"
    },
    "kinematics": {
      "$ref": "#/$defs/KinematicsSettings"
    },
    "model": {
      "$ref": "#/$defs/RuntimeModelSettings"
    },
    "observables": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ObservableSettings"
      }
    },
    "quantities": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/QuantitySettings"
      }
    },
    "sampling": {
      "$ref": "#/$defs/SamplingSettings"
    },
    "selectors": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/SelectorSettings"
      }
    },
    "stability": {
      "$ref": "#/$defs/StabilitySettings"
    },
    "subtraction": {
      "$ref": "#/$defs/SubtractionSettings"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "Dep": {
      "type": "string",
      "enum": [
        "dependent"
      ]
    },
    "DiscreteGraphSamplingType": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "b": {
              "type": "number",
              "format": "double"
            },
            "mapping": {
              "$ref": "#/$defs/ParameterizationMapping"
            },
            "mode": {
              "$ref": "#/$defs/ParameterizationMode"
            },
            "subtype": {
              "type": "string",
              "const": "default"
            }
          },
          "additionalProperties": false,
          "required": [
            "subtype"
          ]
        },
        {
          "type": "object",
          "properties": {
            "alpha": {
              "type": "number",
              "format": "double"
            },
            "parameterization_settings": {
              "$ref": "#/$defs/ParameterizationSettings"
            },
            "subtype": {
              "type": "string",
              "const": "multi_channeling"
            }
          },
          "additionalProperties": false,
          "required": [
            "subtype"
          ]
        },
        {
          "type": "object",
          "properties": {
            "alpha": {
              "type": "number",
              "format": "double"
            },
            "parameterization_settings": {
              "$ref": "#/$defs/ParameterizationSettings"
            },
            "subtype": {
              "type": "string",
              "const": "discrete_multi_channeling"
            }
          },
          "additionalProperties": false,
          "required": [
            "subtype"
          ]
        },
        {
          "type": "object",
          "properties": {
            "matrix_stability_test": {
              "type": [
                "number",
                "null"
              ],
              "format": "double"
            },
            "subtype": {
              "type": "string",
              "const": "tropical"
            },
            "upcast_on_failure": {
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "required": [
            "subtype"
          ]
        }
      ]
    },
    "EntrySelection": {
      "type": "string",
      "enum": [
        "all",
        "leading_only",
        "nth_only"
      ]
    },
    "EvaluatorMethod": {
      "type": "string",
      "enum": [
        "SingleParametric",
        "Iterative",
        "SummedFunctionMap",
        "Summed"
      ]
    },
    "ExternalMomenta": {
      "anyOf": [
        {
          "$ref": "#/$defs/Dep"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/F"
          },
          "maxItems": 4,
          "minItems": 4
        }
      ]
    },
    "Externals": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "helicities": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/Helicity"
                  }
                },
                "improvement_settings": {
                  "$ref": "#/$defs/PhaseSpaceImprovementSettings"
                },
                "momenta": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/ExternalMomenta"
                  }
                }
              },
              "additionalProperties": false,
              "required": [
                "momenta",
                "helicities"
              ]
            },
            "type": {
              "type": "string",
              "const": "constant"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "data"
          ]
        }
      ]
    },
    "F": {
      "type": "number",
      "format": "double"
    },
    "FilterQuantity": {
      "type": "string",
      "enum": [
        "E",
        "CosTheta",
        "PT",
        "y",
        "eta",
        "Px",
        "Py",
        "Pz",
        "Mass"
      ]
    },
    "GeneralSettings": {
      "type": "object",
      "properties": {
        "additional_param_values": {
          "type": "array",
          "items": {
            "type": "number",
            "format": "double"
          }
        },
        "debug_cache": {
          "type": "boolean"
        },
        "disable_flux_factor": {
          "type": "boolean"
        },
        "enable_cache": {
          "type": "boolean"
        },
        "evaluator_method": {
          "$ref": "#/$defs/EvaluatorMethod"
        },
        "generate_events": {
          "type": "boolean"
        },
        "integral_unit": {
          "$ref": "#/$defs/IntegralUnit"
        },
        "load_compiled_cff": {
          "type": "boolean"
        },
        "m_uv": {
          "type": "number",
          "format": "double"
        },
        "mu_r": {
          "type": "number",
          "format": "double"
        },
        "orientation_pat": {
          "$ref": "#/$defs/OrientationPattern"
        },
        "store_additional_weights_in_event": {
          "type": "boolean"
        },
        "use_ltd": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "HFunction": {
      "type": "string",
      "enum": [
        "poly_exponential",
        "exponential",
        "poly_left_right_exponential",
        "exponential_ct"
      ]
    },
    "HFunctionSettings": {
      "type": "object",
      "properties": {
        "enabled_dampening": {
          "type": "boolean"
        },
        "function": {
          "$ref": "#/$defs/HFunction"
        },
        "power": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0
        },
        "sigma": {
          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": false
    },
    "HFunctionTestSettings": {
      "type": "object",
      "properties": {
        "h_function": {
          "$ref": "#/$defs/HFunctionSettings"
        }
      },
      "required": [
        "h_function"
      ]
    },
    "Helicity": {
      "description": "Helicity input. Use -1, 0, or 1 for fixed helicities; or use a string for summed modes.",
      "oneOf": [
        {
          "type": "integer",
          "enum": [
            -1,
            0,
            1
          ]
        },
        {
          "type": "string",
          "enum": [
            "+",
            "-",
            "0",
            "plus",
            "minus",
            "zero",
            "summed",
            "summed_averaged",
            "summed-averaged"
          ]
        }
      ]
    },
    "ImprovementMode": {
      "type": "string",
      "enum": [
        "vh",
        "mf",
        "none"
      ]
    },
    "IntegrandSettings": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "unit_surface"
            }
          },
          "$ref": "#/$defs/UnitSurfaceSettings",
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "unit_volume"
            }
          },
          "$ref": "#/$defs/UnitVolumeSettings",
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "h_function_test"
            }
          },
          "$ref": "#/$defs/HFunctionTestSettings",
          "required": [
            "type"
          ]
        }
      ]
    },
    "IntegralUnit": {
      "type": "string",
      "enum": [
        "auto",
        "picobarn",
        "femtobarn",
        "attobarn",
        "millibarn",
        "none"
      ]
    },
    "IntegratedCounterTermRange": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "h_function_settings": {
              "$ref": "#/$defs/HFunctionSettings"
            },
            "type": {
              "type": "string",
              "const": "infinite"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "h_function_settings"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "compact"
            }
          },
          "additionalProperties": false,
          "required": [
            "type"
          ]
        }
      ]
    },
    "IntegratedCounterTermSettings": {
      "type": "object",
      "properties": {
        "range": {
          "$ref": "#/$defs/IntegratedCounterTermRange"
        }
      },
      "additionalProperties": false
    },
    "IntegratedPhase": {
      "type": "string",
      "enum": [
        "real",
        "imag",
        "both"
      ]
    },
    "IntegratorSettings": {
      "type": "object",
      "properties": {
        "bin_number_evolution": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "integer",
            "format": "uint",
            "minimum": 0
          }
        },
        "continuous_dim_learning_rate": {
          "type": "number",
          "format": "double"
        },
        "discrete_dim_learning_rate": {
          "type": "number",
          "format": "double"
        },
        "integrated_phase": {
          "$ref": "#/$defs/IntegratedPhase"
        },
        "max_prob_ratio": {
          "type": "number",
          "format": "double"
        },
        "min_samples_for_update": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "n_bins": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "n_increase": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "n_max": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "n_start": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "observables_output": {
          "$ref": "#/$defs/ObservablesOutputSettings"
        },
        "seed": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "show_max_wgt_info": {
          "type": "boolean"
        },
        "target_absolute_accuracy": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "target_relative_accuracy": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "train_on_avg": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "JetAlgorithm": {
      "type": "string",
      "enum": [
        "kt",
        "cambridge_aachen",
        "anti_kt"
      ]
    },
    "KinematicsSettings": {
      "type": "object",
      "properties": {
        "e_cm": {
          "type": "number",
          "format": "double"
        },
        "externals": {
          "$ref": "#/$defs/Externals"
        }
      },
      "additionalProperties": false
    },
    "LocalCounterTermSettings": {
      "type": "object",
      "properties": {
        "uv_localisation": {
          "$ref": "#/$defs/UVLocalisationSettings"
        }
      },
      "additionalProperties": false
    },
    "ObservableFileFormat": {
      "type": "string",
      "enum": [
        "none",
        "hwu",
        "json"
      ]
    },
    "ObservablePhase": {
      "type": "string",
      "enum": [
        "real",
        "imag"
      ]
    },
    "ObservableSettings": {
      "type": "object",
      "properties": {
        "entry_index": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "entry_selection": {
          "$ref": "#/$defs/EntrySelection"
        },
        "log_x_axis": {
          "type": "boolean"
        },
        "log_y_axis": {
          "type": "boolean"
        },
        "misbinning_max_normalized_distance": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "n_bins": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "phase": {
          "$ref": "#/$defs/ObservablePhase"
        },
        "quantity": {
          "type": "string"
        },
        "title": {
          "description": "Optional histogram title. Defaults to the observable name when omitted.",
          "type": [
            "string",
            "null"
          ]
        },
        "type_description": {
          "description": "HwU TYPE description written after TYPE@ in the histogram header.",
          "type": "string"
        },
        "value_transform": {
          "$ref": "#/$defs/ObservableValueTransform"
        },
        "x_max": {
          "type": "number",
          "format": "double"
        },
        "x_min": {
          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": false,
      "required": [
        "quantity"
      ]
    },
    "ObservableValueTransform": {
      "type": "string",
      "enum": [
        "identity",
        "log10"
      ]
    },
    "ObservablesOutputSettings": {
      "type": "object",
      "properties": {
        "format": {
          "$ref": "#/$defs/ObservableFileFormat"
        }
      },
      "additionalProperties": false
    },
    "OrientationPattern": {
      "type": "object",
      "properties": {
        "pat": {
          "anyOf": [
            {
              "$ref": "#/$defs/ParseableAtom"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "OverlapSettings": {
      "type": "object",
      "properties": {
        "check_global_center": {
          "type": "boolean"
        },
        "force_global_center": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "double"
            },
            "maxItems": 3,
            "minItems": 3
          }
        },
        "try_origin": {
          "type": "boolean"
        },
        "try_origin_all_lmbs": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "PairQuantity": {
      "type": "string",
      "enum": [
        "DeltaR"
      ]
    },
    "PairingMode": {
      "type": "string",
      "enum": [
        "all_pairs"
      ]
    },
    "ParameterizationMapping": {
      "type": "string",
      "enum": [
        "log",
        "linear"
      ]
    },
    "ParameterizationMode": {
      "type": "string",
      "enum": [
        "cartesian",
        "spherical",
        "hyperspherical",
        "hyperspherical_flat",
        "momentum_space"
      ]
    },
    "ParameterizationSettings": {
      "type": "object",
      "properties": {
        "b": {
          "type": "number",
          "format": "double"
        },
        "mapping": {
          "$ref": "#/$defs/ParameterizationMapping"
        },
        "mode": {
          "$ref": "#/$defs/ParameterizationMode"
        }
      },
      "additionalProperties": false
    },
    "ParseableAtom": {
      "description": "An atom that is serialized as a string. Do not make any assumptions about the state",
      "type": [
        "string"
      ]
    },
    "PhaseSpaceImprovementSettings": {
      "type": "object",
      "properties": {
        "large_deformation_check": {
          "anyOf": [
            {
              "$ref": "#/$defs/F"
            },
            {
              "type": "null"
            }
          ]
        },
        "mode": {
          "$ref": "#/$defs/ImprovementMode"
        },
        "only_warn_on_large_deformation": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "Precision": {
      "type": "string",
      "enum": [
        "Double",
        "Quad",
        "Arb"
      ]
    },
    "QuantityComputation": {
      "type": "string",
      "enum": [
        "scalar",
        "count",
        "pair"
      ]
    },
    "QuantityOrder": {
      "type": "string",
      "enum": [
        "Ascending",
        "Descending"
      ]
    },
    "QuantityOrdering": {
      "type": "string",
      "enum": [
        "PT",
        "Energy",
        "AbsRapidity",
        "Quantity"
      ]
    },
    "QuantitySettings": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "computation": {
              "description": "Quantity computation mode: scalar projection per object, exact object count, or pairwise quantity.",
              "$ref": "#/$defs/QuantityComputation"
            },
            "order": {
              "description": "Sorting direction applied together with ordering.",
              "$ref": "#/$defs/QuantityOrder",
              "examples": [
                "Descending"
              ]
            },
            "ordering": {
              "description": "Ordering key used before entry_selection. Particle scalar quantities default to Quantity, jet scalar quantities default to PT, and pair quantities default to Quantity.",
              "anyOf": [
                {
                  "$ref": "#/$defs/QuantityOrdering"
                },
                {
                  "type": "null"
                }
              ],
              "examples": [
                "Quantity"
              ]
            },
            "pair_quantity": {
              "description": "Pairwise quantity used when computation = \"pair\".",
              "anyOf": [
                {
                  "$ref": "#/$defs/PairQuantity"
                },
                {
                  "type": "null"
                }
              ],
              "examples": [
                "DeltaR"
              ]
            },
            "pairing": {
              "description": "Pairing strategy used when computation = \"pair\".",
              "anyOf": [
                {
                  "$ref": "#/$defs/PairingMode"
                },
                {
                  "type": "null"
                }
              ],
              "examples": [
                "all_pairs"
              ]
            },
            "pdgs": {
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int"
              }
            },
            "quantity": {
              "description": "Per-object scalar quantity used when computation = \"scalar\".",
              "anyOf": [
                {
                  "$ref": "#/$defs/FilterQuantity"
                },
                {
                  "type": "null"
                }
              ],
              "examples": [
                "PT"
              ]
            },
            "type": {
              "type": "string",
              "const": "particle"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "pdgs"
          ]
        },
        {
          "type": "object",
          "properties": {
            "algorithm": {
              "$ref": "#/$defs/JetAlgorithm"
            },
            "clustered_pdgs": {
              "description": "Optional list of PDG IDs allowed to be clustered. Use null to derive the default from the model, or a compact list like [-1,1,21,82] in CLI key-value assignments.",
              "type": [
                "array",
                "null"
              ],
              "examples": [
                [
                  -1,
                  1,
                  21,
                  82
                ]
              ],
              "items": {
                "type": "integer",
                "format": "int"
              }
            },
            "computation": {
              "description": "Quantity computation mode: scalar projection per object, exact object count, or pairwise quantity.",
              "$ref": "#/$defs/QuantityComputation"
            },
            "dR": {
              "type": "number",
              "format": "double"
            },
            "min_jpt": {
              "type": "number",
              "format": "double"
            },
            "order": {
              "description": "Sorting direction applied together with ordering.",
              "$ref": "#/$defs/QuantityOrder",
              "examples": [
                "Descending"
              ]
            },
            "ordering": {
              "description": "Ordering key used before entry_selection. Particle scalar quantities default to Quantity, jet scalar quantities default to PT, and pair quantities default to Quantity.",
              "anyOf": [
                {
                  "$ref": "#/$defs/QuantityOrdering"
                },
                {
                  "type": "null"
                }
              ],
              "examples": [
                "Quantity"
              ]
            },
            "pair_quantity": {
              "description": "Pairwise quantity used when computation = \"pair\".",
              "anyOf": [
                {
                  "$ref": "#/$defs/PairQuantity"
                },
                {
                  "type": "null"
                }
              ],
              "examples": [
                "DeltaR"
              ]
            },
            "pairing": {
              "description": "Pairing strategy used when computation = \"pair\".",
              "anyOf": [
                {
                  "$ref": "#/$defs/PairingMode"
                },
                {
                  "type": "null"
                }
              ],
              "examples": [
                "all_pairs"
              ]
            },
            "quantity": {
              "description": "Per-object scalar quantity used when computation = \"scalar\".",
              "anyOf": [
                {
                  "$ref": "#/$defs/FilterQuantity"
                },
                {
                  "type": "null"
                }
              ],
              "examples": [
                "PT"
              ]
            },
            "type": {
              "type": "string",
              "const": "jet"
            }
          },
          "additionalProperties": false,
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "a_f_b"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "cross_section"
            }
          },
          "required": [
            "type"
          ]
        }
      ]
    },
    "RotationSetting": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "x"
            }
          },
          "additionalProperties": false,
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "y"
            }
          },
          "additionalProperties": false,
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
