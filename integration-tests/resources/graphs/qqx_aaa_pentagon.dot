digraph qqx_aaa_pentagon {
  overall_factor = "-1";
  overall_factor_evaluated = "-1";
  projector = "(1/3) * spenso::g(spenso::dind(spenso::cof(3,gammalooprs::hedge(1))),spenso::cof(3,gammalooprs::hedge(0))) * u(0,spenso::bis(4,hedge(0)))*vbar(1,spenso::bis(4,hedge(1)))*ϵbar(2,spenso::mink(4,hedge(2)))*ϵbar(3,spenso::mink(4,hedge(3)))*ϵbar(4,spenso::mink(4,hedge(4)))";

  // num = "1"; // Substitute this with your complete numerator string

  // edge [ num="1" ] // When opting to supply the whole numerator in the above, then remove the localized numerator specification per edge by uncommenting this
  // node [ num="1" ] // When opting to supply the whole numerator in the above, then remove the localized numerator specification per node by uncommenting this

  ext   [style=invis];

  ext	-> 0:0	 [id=0 particle="d"];
  ext	-> 1:1	 [id=1 particle="d~"];
  2:2	-> ext	 [id=2 particle="a"];
  3:3	-> ext	 [id=3 particle="a"];
  4:4	-> ext   [id=4 particle="a"];

  0	-> 2	 [id=5 particle="d"];
  2	-> 3	 [id=6 particle="d"];
  3	-> 4	 [id=7 particle="d"];
  4 -> 1     [id=8 particle="d"];
  // 1 -> 0     [id=9 lmb_id="0" particle="g"];
  // The option below would introduce an IR regulator
  1 -> 0     [id=9 lmb_id="0" particle="g" mass="1"];
}

