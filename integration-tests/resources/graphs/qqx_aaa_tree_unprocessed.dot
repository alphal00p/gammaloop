digraph qqx_aaa_tree_1 {
            projector = "(1i)*1/3*spenso::g(spenso::cof(3,hedge(2)),spenso::dind(spenso::cof(3,hedge(1))))*u(1,spenso::bis(4,hedge(1)))*vbar(2,spenso::bis(4,hedge(2)))*ϵbar(0,spenso::mink(4,hedge(0)))*ϵbar(3,spenso::mink(4,hedge(3)))*ϵbar(4,spenso::mink(4,hedge(4)))";

            ext    [style=invis]
            ext -> v1:1 [particle="d" id=1];
            ext -> v3:2 [particle="d~" id=2];
            v1:3 -> ext [particle="a" id=3];
            v2:4 -> ext [particle="a" id=4];
            v3:0 -> ext [particle="a" id=0];
            v1:5 -> v2:6 [particle="d" id=5];
            v2 -> v3 [particle="d" id=6];
}
