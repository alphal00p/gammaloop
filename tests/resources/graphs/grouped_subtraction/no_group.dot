digraph triangle_with_4_externals {
    graph [
        overall_factor = 1;
    ]
    edge [
        pdg=1000
    ]
    ext [style=invis]
    ext -> v4 [id=0]
    ext -> v4 [id=1]
    ext -> v5 [id=2]
    v6 -> ext [id=3]
    v5 -> v4 [lmb_index=0];
    v6 -> v5;
    v4 -> v6 ;
}

digraph box {
    graph [
        overall_factor = 1;
    ]
    edge [
        pdg=1000
    ]
    ext [style=invis] 
    ext -> v1 [id=0]
    ext -> v2 [id=1]
    ext -> v3 [id=2]
    v4 -> ext [id=3]
    v1 -> v2 [lmb_index=0]
    v2 -> v3 
    v3 -> v4 
    v4 -> v1
}