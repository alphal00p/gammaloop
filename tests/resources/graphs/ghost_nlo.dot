digraph d1 {

projector = "spenso::g(spenso::coad(8,hedge(0)),spenso::coad(8,hedge(1)))"

in1 [style=invis];
in1 -> v1:0
[particle="ghG" pin="x:@-left"];

out1 [style=invis];
v2:1 -> out1
[particle="ghG" pin="x:@+right"];

v1 -> v3 [particle= "g"];
v1 -> v4 [particle= "ghG"];
v2 -> v3 [particle= "g"];
v4 -> v2 [particle= "ghG"];
v3 -> v4 [particle= "g"];
}
