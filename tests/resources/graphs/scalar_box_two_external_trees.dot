ext -> T1:2 [particle="scalar_0" id=2];
T1:3 -> ext [particle="scalar_0" id=3];
T2:4 -> ext [particle="scalar_0" id=4];
T2:5 -> ext [particle="scalar_0" id=5];
A -> B [particle="scalar_1" id=6, lmb_id=0];
B -> C [particle="scalar_1" id=7];
C -> D [particle="scalar_1" id=8];
D -> A [particle="scalar_1" id=9];
B -> T1 [particle="scalar_1" id=10];
D -> T2 [particle="scalar_1" id=11];
}
