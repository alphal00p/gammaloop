digraph photon_box {
    edge [
        dod = -100
    ]
    node [
        dod = -100
    ]
    ext [style=invis]
    ext -> v1:0 [particle=a, id=0];
    ext -> v2:1 [particle=a, id=1];
    v3:2 -> ext [particle=a, id=2];
    v4:3 -> ext [particle=a, id=3];
    v1 -> v2 [particle=t, id=4, lmb_id=0];
    v2 -> v3 [particle=t, id=5];
    v3 -> v4 [particle=t, id=6];
    v4 -> v1 [particle=t, id=7];
}