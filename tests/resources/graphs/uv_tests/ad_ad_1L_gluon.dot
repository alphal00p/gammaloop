digraph adad {

    num =
    "spenso::g(spenso::dind(spenso::cof(3,gammalooprs::hedge(1))),spenso::cof(3,gammalooprs::hedge(3)))"
    ext [style=invis];

    ext -> v1:0 [id=0 particle="a"];
    ext -> v1:1 [id=1 particle="d"];
    v4:2 -> ext [id=2 particle="a"];
    v4:3 -> ext [id=3 particle="d"];
    v1 -> v2 -> v3 -> v4 [particle="d"]
    v2 -> v3 [particle="g"]
}
