---
source: src/graph/lmb.rs
expression: "g.dot_lmb(&g.full_filter(), &g.loop_momentum_basis)"
---
digraph {
  node	 [shape=circle,height=0.1,label=""];
  overlap = "scale";
  layout = "neato";
  start=2;
  0	 [label=""];
  ext0	 [style=invis];
  ext0	-> 0:0:s	 [id=0 color="blue" label="Q(0)"];
  ext1	 [style=invis];
  ext1	-> 0:1:s	 [id=1 color="blue" label="-Q(2)"];
  ext2	 [style=invis];
  ext2	-> 0:2:s	 [id=2 color="blue" label="Q(2)"];
}
