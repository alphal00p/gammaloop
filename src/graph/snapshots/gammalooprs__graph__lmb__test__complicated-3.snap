  ext7	 [style=invis];
  ext7	-> 4:7:s	 [id=7 color="blue" label="-Q(8)-Q(9)"];
  ext8	 [style=invis];
  ext8	-> 4:8:s	 [id=8 color="blue" label="Q(8)"];
  ext9	 [style=invis];
