---
source: src/graph/lmb.rs
expression: "g.dot_lmb_of(&non_dummy, &lmb)"
---
digraph {
  node	 [shape=circle,height=0.1,label=""];
  overlap = "scale";
  layout = "neato";
  start=2;
  0	 [label=""];
  1	 [label=""];
  2	 [label=""];
  ext0	 [style=invis];
  ext0	-> 0:0	 [id=0 color="gray" label="Q(0)"];
  ext1	 [style=invis];
  ext1	-> 0:1:s	 [id=1 color="blue" label="Q(1)"];
  ext2	 [style=invis];
  ext2	-> 1:2:s	 [id=2 color="blue" label="Q(2)"];
  ext3	 [style=invis];
  ext3	-> 2:3:s	 [id=3 color="blue" label="-Q(0)-Q(1)-Q(2)"];
  0:4:s	-> 1:5:s	 [id=4  color="red:blue;0.5" label="-Q(2)+Q(6)"];
  0:6:s	-> 2:7:s	 [id=5  color="red:blue;0.5" label="Q(5)"];
  1:8:s	-> 2:9:s	 [id=6  color="red:blue;0.5" label="Q(6)"];
  2:10:s	-> 0:11:s	 [id=7  color="red:blue;0.5" label="-Q(0)-Q(1)-Q(2)+Q(5)+Q(6)"];
}
