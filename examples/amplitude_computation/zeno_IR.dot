digraph qq_AAA_pentagon_soft{
graph	 [num = "spenso::gamma(spenso::bis(4,s1000),spenso::bis(4,s1),spenso::mink(4,tau1))*
                spenso::gamma(spenso::bis(4,s1),spenso::bis(4,s2),spenso::mink(4,sigma1))*Q(7,spenso::mink(4,sigma1))*
                spenso::gamma(spenso::bis(4,s2),spenso::bis(4,s3),spenso::mink(4,nu1))*
                spenso::gamma(spenso::bis(4,s3),spenso::bis(4,s4),spenso::mink(4,sigma2))*(Q(0,spenso::mink(4,sigma2))-Q(1,spenso::mink(4,sigma2)))*
                spenso::gamma(spenso::bis(4,s4),spenso::bis(4,s5),spenso::mink(4,nu2))*
                spenso::gamma(spenso::bis(4,s5),spenso::bis(4,s6),spenso::mink(4,sigma3))*(Q(0,spenso::mink(4,sigma3))-Q(1,spenso::mink(4,sigma3))-Q(2,spenso::mink(4,sigma3)))*
                spenso::gamma(spenso::bis(4,s6),spenso::bis(4,s7),spenso::mink(4,nu3))*
                spenso::gamma(spenso::bis(4,s7),spenso::bis(4,s8),spenso::mink(4,sigma4))*Q(8,spenso::mink(4,sigma4))*
                spenso::gamma(spenso::bis(4,s8),spenso::bis(4,s1001),spenso::mink(4,tau1))", 
        overall_factor = "1", 
        projector = "u(0,spenso::bis(4,s1001))*
                    ϵ(1,spenso::mink(4,nu1))*
                    ϵ(2,spenso::mink(4,nu2))*
                    ϵbar(3,spenso::mink(4,nu3))*
                    vbar(4,spenso::bis(4,s1000))"]

        edge[
            num=1 dod=-100]
        node[
            num=1 dod=-100]

            ext    [style=invis]
            ext0    [style=invis]

			ext -> v0 [id=0];
            v1 -> ext [id=1];
            v1 -> ext [id=2];
            v1 -> ext [id=3];
            ext -> v4 [id=4];

            //eta1 externals
            ext -> v0 [id=5];
            v0 -> ext [id=6];   

            v0 -> v1 [id=7];
            v1 -> v4 [id=8];
            v4 -> v0 [id=9 lmb_id = 0];
}

